# Use hoisted node_modules so tools like tsx and tsc can find packages
node-linker=hoisted

# Ensure workspace packages are symlinked locally instead of fetched from npm
link-workspace-packages=true

# Prevent packages from accessing undeclared dependencies
strict-peer-dependencies=false

# npm registry for publishing @openiac/* packages
registry=https://registry.npmjs.org/

# Auth token for publishing (set this in your CI environment, not here)
# //registry.npmjs.org/:_authToken=${NPM_TOKEN}
